# ── Database (Neon Postgres) ──────────────────────────────────────────────────
# Pooled connection — used by the app at runtime (PgBouncer).
# On Vercel: auto-injected by the Neon Storage integration.
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require&pgbouncer=true"

# Direct (non-pooled) connection — used by Prisma migrations only.
# On Vercel: auto-injected by the Neon Storage integration.
DIRECT_URL="postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<db>?sslmode=require"

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Random secret for signing JWT session tokens.
# Generate with: npx auth secret   OR   openssl rand -base64 32
AUTH_SECRET=""

# ── Triage helper ─────────────────────────────────────────────────────────────
# "rules" (default, zero-cost, offline) or "llm" (OpenRouter-backed).
# Omit this line entirely to use the rules engine.
TRIAGE_MODE="rules"

# Required only when TRIAGE_MODE=llm.
# If unset, the app falls back to the rules engine automatically.
OPENROUTER_API_KEY=""

# Optional: override the OpenRouter model used in LLM mode.
# Defaults to anthropic/claude-haiku-4.5 when unset.
# TRIAGE_MODEL="anthropic/claude-haiku-4.5"
